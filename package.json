{
  "name": "tiptap-react-ui",
  "version": "1.0.0",
  "description": "A customizable React rich text editor powered by Tiptap.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/knnthdn/tiptap-react-ui.git"
  },
  "homepage": "https://github.com/knnthdn/tiptap-react-ui#readme",
  "bugs": {
    "url": "https://github.com/knnthdn/tiptap-react-ui/issues"
  },
  "keywords": [
    "react",
    "tiptap",
    "editor",
    "rich-text-editor",
    "wysiwyg",
    "notion-editor",
    "wysiwyg rich-text-editor",
    "pre-built rich-text-editor"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs.js"
    },
    "./dist/index.css": "./dist/index.css",
    "./style.css": "./dist/index.css"
  },
  "style": "./dist/index.css",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/scope-public-css.mjs",
    "prepublishOnly": "npm run build",
    "lint": "eslint .",
    "preview": "vite preview",
    "pack:test": "node scripts/pack-and-install.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@microsoft/api-extractor": "^7.58.7",
    "@tailwindcss/vite": "^4.3.0",
    "@tiptap/core": "^3.23.6",
    "@tiptap/pm": "^3.23.6",
    "@tiptap/react": "^3.23.6",
    "@types/chroma-js": "^3.1.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.3",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sass-embedded": "^1.100.0",
    "shadcn": "^4.8.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^5.0.0"
  },
  "peerDependencies": {
    "@tiptap/core": ">=3.23.0 <4",
    "@tiptap/pm": ">=3.23.0 <4",
    "@tiptap/react": ">=3.23.0 <4",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.19",
    "@tiptap/extension-code-block-lowlight": ">=3.23.0 <4",
    "@tiptap/extension-drag-handle": ">=3.23.0 <4",
    "@tiptap/extension-drag-handle-react": ">=3.23.0 <4",
    "@tiptap/extension-highlight": ">=3.23.0 <4",
    "@tiptap/extension-image": ">=3.23.0 <4",
    "@tiptap/extension-link": ">=3.23.0 <4",
    "@tiptap/extension-list": ">=3.23.0 <4",
    "@tiptap/extension-node-range": ">=3.23.0 <4",
    "@tiptap/extension-table": ">=3.23.0 <4",
    "@tiptap/extension-table-of-contents": ">=3.23.0 <4",
    "@tiptap/extension-text-align": ">=3.23.0 <4",
    "@tiptap/extension-text-style": ">=3.23.0 <4",
    "@tiptap/extension-youtube": ">=3.23.0 <4",
    "@tiptap/extensions": ">=3.23.0 <4",
    "chroma-js": "^3.2.0",
    "cmdk": "^1.1.1",
    "highlight.js": "^11.8.0",
    "lowlight": "^3.0.0",
    "react-hotkeys-hook": "^5.3.2",
    "@tiptap/starter-kit": ">=3.23.0 <4",
    "lucide-react": "^1.0.0",
    "radix-ui": "^1.4.3"
  }
}
